  "modified": "2026-03-05 12:47:38.273877",
  "module": "Helpdesk",
  "name": "My HD Tickets",
  "prepared_report": 0,
  "query": "",
  "ref_doctype": "HD Ticket",
  "reference_report": null,
  "report_name": "My HD Tickets",
  "report_script": "# Custom Script Report (Report.report_script) style\n# Output via old-style: data = [columns, rows]\n\nfilters = filters or {}\n\n# Be tolerant of different callers / route filters\nuser = (\n    (filters.get(\"user\") if isinstance(filters, dict) else None)\n    or (filters.get(\"assigned_user\") if isinstance(filters, dict) else None)\n    or frappe.session.user\n    or \"\"\n).strip()\n\ncolumns = [\n    {\"label\": \"Ticket\", \"fieldname\": \"ticket\", \"fieldtype\": \"Link\", \"options\": \"HD Ticket\", \"width\": 120},\n    {\"label\": \"Subject\", \"fieldname\": \"subject\", \"fieldtype\": \"Data\", \"width\": 360},\n    {\"label\": \"Status\", \"fieldname\": \"status\", \"fieldtype\": \"Data\", \"width\": 100},\n    {\"label\": \"Priority\", \"fieldname\": \"priority\", \"fieldtype\": \"Data\", \"width\": 100},\n    {\"label\": \"Team\", \"fieldname\": \"team\", \"fieldtype\": \"Data\", \"width\": 120},\n    {\"label\": \"Modified\", \"fieldname\": \"modified\", \"fieldtype\": \"Datetime\", \"width\": 160},\n]\n\nif not user:\n    rows = []\nelse:\n    rows = frappe.db.sql(\n        \"\"\"\n        SELECT\n          t.name as ticket,\n          t.subject,\n          t.status,\n          t.priority,\n          t.agent_group as team,\n          t.modified\n        FROM `tabHD Ticket` t\n        WHERE EXISTS (\n          SELECT 1\n          FROM `tabToDo` td\n          WHERE td.reference_type = 'HD Ticket'\n            AND td.reference_name = t.name\n            AND td.allocated_to = %(user)s\n            AND td.status = 'Open'\n        )\n        ORDER BY t.modified DESC\n        LIMIT 200\n        \"\"\",\n        {\"user\": user},\n        as_dict=True,\n    )\n\ndata = [columns, rows]\n",
  "report_type": "Script Report",
  "roles": [
