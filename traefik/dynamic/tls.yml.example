# Example Traefik dynamic TLS configuration for a supplied/manual certificate.
#
# Copy this file to:
#
#   traefik/dynamic/tls.yml
#
# on the production server and adjust paths to match the supplied certificate files.
#
# Do not commit real certificate files or private keys.

tls:
  certificates:
    - certFile: /certs/production.crt
      keyFile: /certs/production.key