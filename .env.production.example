# Production environment example.
#
# Copy to a server-local env file during production deployment.
# Do not commit the real production env file.
# Do not use these example values as real secrets.

# Production frontend/nginx image.
# Must be a tested, pinned tag. Do not use moving tags such as "edge" for production.
#
# Example placeholder only. Confirm the valid tag during the production image strategy slice.
ERPNEXT_NGINX_IMAGE=frappe/erpnext:v15.94.1

# Final public production hostname users will open in the browser.
#
# Telectro's reverse proxy / HTTPS layer owns public routing for this hostname.
# The application stack does not use this for Traefik routing.
# Keep this value for deployment notes, smoke checks, email link expectations,
# and operator clarity.
PRODUCTION_HOSTNAME=support.telectro.co.za

# Frappe site name.
#
# Prefer aligning this with the public production hostname so browser requests,
# email links, and Frappe site routing stay consistent.
SITE_NAME=support.telectro.co.za

# Internal HTTP target exposed by the application stack for Telectro's reverse proxy.
#
# Default is conservative for a same-VM reverse proxy:
#
#   127.0.0.1:8080 -> frontend:8080
#
# If Telectro's reverse proxy runs on another host and must reach this VM over
# the network, set APP_INTERNAL_HTTP_BIND explicitly after firewall approval,
# for example:
#
#   APP_INTERNAL_HTTP_BIND=0.0.0.0
#
# Do not expose this internal HTTP target publicly without Telectro firewall /
# reverse proxy approval.
APP_INTERNAL_HTTP_BIND=127.0.0.1
APP_INTERNAL_HTTP_PORT=8080

# Debug must be off in production.
TELECTRO_DEBUG=0

# Production database root password.
#
# Generate a unique value for the production server.
# Keep the real value outside Git.
# The production Compose override derives both MYSQL_ROOT_PASSWORD and
# MARIADB_ROOT_PASSWORD from this value.
MARIADB_ROOT_PASSWORD=replace-with-production-mariadb-root-password

# Initial Frappe Administrator password for site creation.
#
# Generate a unique value for the production server.
# Keep the real value outside Git.
FRAPPE_ADMIN_PASSWORD=replace-with-production-frappe-admin-password

# Database connection defaults used during site creation.
DB_ROOT_USERNAME=root
DB_HOST=db
DB_PORT=3306

# SMTP values should normally be configured in Frappe Email Account.
# Only add environment-driven SMTP values later if explicitly required.
# Keep real SMTP credentials outside Git.
SMTP_SERVER=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=