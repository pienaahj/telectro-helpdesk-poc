# Production environment example.
#
# Copy to a server-local env file during production deployment.
# Do not commit real production secrets.

# Final production hostname users will open in the browser.
PRODUCTION_HOSTNAME=support.telectro.co.za

# Frappe site name.
# Prefer aligning this with the production hostname.
SITE_NAME=support.telectro.co.za

# Debug must be off in production.
TELECTRO_DEBUG=0

# Database values shown here are placeholders only.
# Real values must be stored outside Git.
#
# Current compose still uses both MYSQL_ROOT_PASSWORD and MARIADB_ROOT_PASSWORD.
# Keep them aligned until the compose secrets model is cleaned up.
MYSQL_ROOT_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me

# Initial site creation values.
# These are placeholders only and are not fully wired into compose yet.
# Real values must be generated per deployment and kept outside Git.
FRAPPE_ADMIN_PASSWORD=change-me
DB_ROOT_USERNAME=root
DB_HOST=db
DB_PORT=3306

# SMTP values should be configured in Frappe Email Account where possible.
# If environment values are used later, keep real values outside Git.
SMTP_SERVER=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=